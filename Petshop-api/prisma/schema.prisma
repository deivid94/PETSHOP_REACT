// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"

}

datasource db {
  provider = "postgresql"
  
  }

enum Status {
  PENDING
  COMPLETED
  CANCELED
}

enum Species {
  CACHORRO
  GATO
  COELHO
  OTHER
}

model User {
  clientId String @id @default(uuid())
  name String
  lastname String
  phone String
  email String
  address String
  pets Pet[]
  @@map("users")
 
}

model Pet {
  petId String @id @default(uuid())
  name String?
  species Species @default(CACHORRO)
  clientId String
  schedules Schedule[]
  user User @relation(fields: [clientId], references: [clientId])
@@map("pets")

}

model Schedule {
  id String @id @default(uuid())
  date DateTime
  createdAt DateTime @default(now())
  petId String
  pet Pet @relation(fields: [petId], references: [petId])
  services Service []
  status Status @default(PENDING)
  @@map("agendamentos")
}

model Service {
  id String @id @default(uuid())
  name String
  price Float
  schedules Schedule[]
  @@map("servicos")
}

