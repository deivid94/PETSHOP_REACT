// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  
}

enum Status {
  PENDING
  COMPLETED
  CANCELED
}

enum Species {
  CACHORRO
  GATO
  COELHO
  OTHER
}

model User {
  clientId Int @id @default(autoincrement())
  name String
  lastname String
  phone Int
  email String
  address String
  pets Pet[]
 
}

model Pet {
  petId Int @id @default(autoincrement())
  name String?
  species Species @default(CACHORRO)
  clientId Int
  schedules Schedule[]
  user User @relation(fields: [clientId], references: [clientId])


}

model Schedule {
  id Int @id @default(autoincrement())
  date DateTime
  createdAt DateTime @default(now())
  petId Int
  pet Pet @relation(fields: [petId], references: [petId])
  services Service []
  status Status @default(PENDING)
  

}

model Service {
  id Int @id @default(autoincrement())
  name String
  price Float
  schedules Schedule[]
  
}

